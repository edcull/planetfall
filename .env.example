# Planetfall Configuration
# Copy this file to .env and fill in your values.

# Anthropic API key (required for AI narrative backgrounds and orchestrator)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Orchestrator mode: api | hybrid | local
# - api:    Claude drives all 18 steps (richest narrative, slowest — many API round-trips)
# - hybrid: Local mechanics + Claude API narrative at 3 key moments per turn (fast + immersive)
# - local:  Pure Python, template narrative, zero API calls (fastest)
ORCHESTRATOR_MODE=hybrid

# Claude model for full API orchestrator mode (optional, defaults to sonnet)
NARRATIVE_MODEL=claude-sonnet-4-20250514

# Claude model for hybrid-mode narrative bursts (optional, defaults to haiku — fast & cheap)
HYBRID_NARRATIVE_MODEL=claude-haiku-4-5-20251001

# Claude model for character backgrounds — short text (optional, defaults to haiku)
BACKGROUND_MODEL=claude-haiku-4-5-20251001

# Enable manual dice mode by default (optional, true/false)
MANUAL_DICE=false
